{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "SpecSchema/v1",
  "title": "SpecSchema v1",
  "description": "has-udd Spec 集約（UDD の核）。specKind=bounded-context/domain-model/usecase（DDD3層）。content はドメイン語彙のみ（技術スタック/アーキ構成は CodingTemplate の担当・ここには入れない）。集約の振る舞い=Commands、ユースケースの流れ=MainFlow(シーケンス)、整合の契約=TestScenarios(Gherkin)。",

  "x-render-target": {
    "formats": ["html", "feature"],
    "path": ".has-udd/specs/{documentId}.html",
    "featurePath": ".has-udd/specs/{documentId}.feature"
  },
  "x-source-target": ".has-udd/documents/specs/{documentId}.json",

  "type": "object",
  "required": ["documentId", "documentType", "schemaRef", "specKind", "status", "content"],
  "properties": {
    "documentId": {
      "type": "string",
      "x-prompt-write": "この Spec を一意に識別する ID を kebab-case で。usecase は uc-、domain-model は dm-、bounded-context は bc- 接頭辞を推奨。例: uc-create-order"
    },
    "documentType": { "type": "string", "const": "Spec" },
    "schemaRef":    { "type": "string", "const": "SpecSchema/v1" },
    "specKind": {
      "type": "string",
      "enum": ["bounded-context", "domain-model", "usecase"],
      "x-prompt-write": "DDD3層のどれか。bounded-context(戦略・1文脈) / domain-model(戦術・1集約) / usecase(アプリ・1操作)。"
    },
    "status": {
      "type": "string",
      "enum": ["CREATED", "VALIDATED", "RENDERED", "SUPERSEDED"],
      "x-prompt-write": "作成直後は CREATED。検証通過で VALIDATED、render 済で RENDERED、後続版に置換で SUPERSEDED。"
    },
    "aggregateRef": {
      "type": "string",
      "x-prompt-write": "usecase のみ: この操作が対象とする集約(domain-model)の documentId。保存する唯一の参照（アプリ→ドメインの依存）。"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "x-prompt-write": "この Spec を分類するタグ。例: [\"context:orders\"]"
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },

    "_index": {
      "description": "has-udd が x-prompt-query から自動生成する。AI は直接書かない。",
      "readOnly": true,
      "type": "object",
      "properties": {
        "blocks": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["blockType", "prompt"],
            "properties": {
              "blockType": { "type": "string" },
              "prompt":    { "type": "string" }
            }
          }
        }
      }
    },

    "content": { "type": "object" }
  },

  "allOf": [
    { "if":   { "properties": { "specKind": { "const": "bounded-context" } }, "required": ["specKind"] },
      "then": { "properties": { "content": { "$ref": "#/$defs/BoundedContextContent" } } } },
    { "if":   { "properties": { "specKind": { "const": "domain-model" } }, "required": ["specKind"] },
      "then": { "properties": { "content": { "$ref": "#/$defs/DomainModelContent" } } } },
    { "if":   { "properties": { "specKind": { "const": "usecase" } }, "required": ["specKind"] },
      "then": { "properties": { "content": { "$ref": "#/$defs/UsecaseContent" } } } }
  ],

  "$defs": {

    "BoundedContextContent": {
      "type": "object",
      "required": ["title", "purpose", "subdomainClassification", "ubiquitousLanguage"],
      "additionalProperties": false,
      "properties": {
        "title":                   { "$ref": "#/$defs/TitleBlock" },
        "purpose":                 { "$ref": "#/$defs/PurposeBlock" },
        "subdomainClassification": { "$ref": "#/$defs/SubdomainClassificationBlock" },
        "ubiquitousLanguage":      { "$ref": "#/$defs/UbiquitousLanguageBlock" }
      }
    },

    "DomainModelContent": {
      "type": "object",
      "required": ["title", "purpose", "aggregateRoot", "commands", "unitTestScenarios"],
      "additionalProperties": false,
      "properties": {
        "title":             { "$ref": "#/$defs/TitleBlock" },
        "purpose":           { "$ref": "#/$defs/PurposeBlock" },
        "aggregateRoot":     { "$ref": "#/$defs/AggregateRootBlock" },
        "valueObjects":      { "$ref": "#/$defs/ValueObjectsBlock" },
        "entities":          { "$ref": "#/$defs/EntitiesBlock" },
        "commands":          { "$ref": "#/$defs/CommandsBlock" },
        "domainEvents":      { "$ref": "#/$defs/DomainEventsBlock" },
        "domainServices":    { "$ref": "#/$defs/DomainServicesBlock" },
        "lifecycle":         { "$ref": "#/$defs/LifecycleBlock" },
        "unitTestScenarios": { "$ref": "#/$defs/UnitTestScenariosBlock" }
      }
    },

    "UsecaseContent": {
      "type": "object",
      "required": ["title", "purpose", "actorIntent", "mainFlow", "acceptanceCriteria", "testScenarios"],
      "additionalProperties": false,
      "properties": {
        "title":              { "$ref": "#/$defs/TitleBlock" },
        "purpose":            { "$ref": "#/$defs/PurposeBlock" },
        "actorIntent":        { "$ref": "#/$defs/ActorIntentBlock" },
        "preconditions":      { "$ref": "#/$defs/PreconditionsBlock" },
        "mainFlow":           { "$ref": "#/$defs/MainFlowBlock" },
        "postconditions":     { "$ref": "#/$defs/PostconditionsBlock" },
        "acceptanceCriteria": { "$ref": "#/$defs/AcceptanceCriteriaBlock" },
        "errors":             { "$ref": "#/$defs/ErrorsBlock" },
        "testScenarios":      { "$ref": "#/$defs/TestScenariosBlock" }
      }
    },

    "TitleBlock": {
      "type": "object",
      "required": ["blockType", "title"],
      "x-render-order": 0,
      "x-render-level": 1,
      "x-prompt-query": "この Spec のタイトルを持ちます。documentId が使われ h1 になります。",
      "x-render": [],
      "properties": {
        "blockType": { "type": "string", "const": "Title" },
        "title":     { "type": "string", "x-prompt-write": "documentId をそのまま設定してください。" }
      }
    },

    "PurposeBlock": {
      "type": "object",
      "required": ["blockType", "title", "text"],
      "x-render-order": 1,
      "x-render-level": 2,
      "x-prompt-query": "この Spec の目的を1〜2文で持ちます。Spec の選択・理解に使います。",
      "x-render": [ { "as": "paragraph", "from": "text" } ],
      "properties": {
        "blockType": { "type": "string", "const": "Purpose" },
        "title":     { "type": "string", "const": "目的" },
        "text":      { "type": "string", "x-prompt-write": "この文脈/集約/ユースケースが達成する業務目的を1〜2文で（ドメイン語彙のみ・技術用語禁止）。" }
      }
    },

    "SubdomainClassificationBlock": {
      "type": "object",
      "required": ["blockType", "title", "classification", "reason"],
      "x-render-order": 2,
      "x-render-level": 2,
      "x-prompt-query": "この文脈のサブドメイン分類(中核/一般/補完)と理由を持ちます。戦略的優先度の判定に使います。",
      "x-render": [
        { "as": "keyvalue", "pairs": [
          { "label": "分類", "from": "classification" },
          { "label": "理由", "from": "reason" }
        ] }
      ],
      "properties": {
        "blockType":      { "type": "string", "const": "SubdomainClassification" },
        "title":          { "type": "string", "const": "サブドメイン分類" },
        "classification": { "type": "string", "enum": ["core", "supporting", "generic"], "x-prompt-write": "中核=core / 補完=supporting / 一般=generic。" },
        "reason":         { "type": "string", "x-prompt-write": "その分類の理由（競争優位を生むか・既製品があるか 等）。" }
      }
    },

    "UbiquitousLanguageBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 3,
      "x-render-level": 2,
      "x-prompt-query": "この文脈のユビキタス言語(用語→定義)を持ちます。AI の grounding・語彙統一に使います。",
      "x-render": [
        { "as": "table", "from": "items", "columns": [
          { "field": "term", "header": "用語", "code": true },
          { "field": "definition", "header": "定義" }
        ] }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "UbiquitousLanguage" },
        "title":     { "type": "string", "const": "ユビキタス言語" },
        "items": {
          "type": "array",
          "x-prompt-write": "この文脈の用語と定義を列挙。業務エキスパートと同じ言葉で（技術用語を混ぜない）。",
          "items": {
            "type": "object",
            "required": ["term", "definition"],
            "properties": {
              "term":       { "type": "string", "x-prompt-write": "用語（この文脈での呼び名）。" },
              "definition": { "type": "string", "x-prompt-write": "その用語が指すものを1文で。" }
            }
          }
        }
      }
    },

    "AggregateRootBlock": {
      "type": "object",
      "required": ["blockType", "title", "name", "identifier", "invariants"],
      "x-render-order": 2,
      "x-render-level": 2,
      "x-prompt-query": "集約のルートエンティティ・識別子・不変条件・外部集約参照を持ちます。集約境界と一貫性の核です。",
      "x-render": [
        { "as": "keyvalue", "pairs": [
          { "label": "ルート", "from": "name" },
          { "label": "識別子", "from": "identifier" }
        ] },
        { "as": "list", "heading": "不変条件", "from": "invariants" },
        { "as": "list", "heading": "外部集約参照（ID）", "from": "externalRefs" }
      ],
      "properties": {
        "blockType":  { "type": "string", "const": "AggregateRoot" },
        "title":      { "type": "string", "const": "集約ルート" },
        "name":       { "type": "string", "x-prompt-write": "ルートエンティティ名（ドメイン語彙）。例: Order" },
        "identifier": { "type": "string", "x-prompt-write": "識別子の概念名（値オブジェクト）。例: OrderId" },
        "invariants": {
          "type": "array",
          "x-prompt-write": "集約が常に満たす不変条件を列挙（「〜は常に〜」の形・業務ルールはここに集約）。",
          "items": { "type": "string" }
        },
        "externalRefs": {
          "type": "array",
          "x-prompt-write": "ID で参照する他集約を列挙（オブジェクトは内部に持たない・図6-4）。例: Customer, Product。無ければ空。",
          "items": { "type": "string" }
        }
      }
    },

    "ValueObjectsBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 3,
      "x-render-level": 2,
      "x-prompt-query": "値オブジェクト(属性の組合せ・不変・等価判定)を持ちます。",
      "x-render": [
        { "as": "section", "from": "items", "titleFrom": "name", "each": [
          { "as": "table", "heading": "属性", "from": "attributes", "columns": [
            { "field": "name", "header": "属性" },
            { "field": "meaning", "header": "意味" }
          ] },
          { "as": "paragraph", "heading": "等価判定", "from": "equality" }
        ] }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "ValueObjects" },
        "title":     { "type": "string", "const": "値オブジェクト" },
        "items": {
          "type": "array",
          "x-prompt-write": "値で区別される不変オブジェクトを列挙。無ければ空。",
          "items": {
            "type": "object",
            "required": ["name", "attributes", "equality"],
            "properties": {
              "name": { "type": "string", "x-prompt-write": "値オブジェクト名。例: Money" },
              "attributes": {
                "type": "array",
                "x-prompt-write": "属性（フィールド）を列挙。",
                "items": {
                  "type": "object",
                  "required": ["name", "meaning"],
                  "properties": {
                    "name":    { "type": "string", "x-prompt-write": "属性名。例: amount" },
                    "meaning": { "type": "string", "x-prompt-write": "その属性の意味を1文で。" }
                  }
                }
              },
              "equality": { "type": "string", "x-prompt-write": "等価判定の基準（どの属性が等しければ等価か）。例: amount と currency が等しければ等価。" }
            }
          }
        }
      }
    },

    "EntitiesBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 4,
      "x-render-level": 2,
      "x-prompt-query": "集約内のエンティティ(識別子＋状態)を持ちます。",
      "x-render": [
        { "as": "section", "from": "items", "titleFrom": "name", "each": [
          { "as": "keyvalue", "pairs": [ { "label": "識別子", "from": "identifier" } ] },
          { "as": "paragraph", "from": "description" },
          { "as": "table", "heading": "属性", "from": "attributes", "columns": [
            { "field": "name", "header": "属性" },
            { "field": "meaning", "header": "意味" }
          ] }
        ] }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "Entities" },
        "title":     { "type": "string", "const": "エンティティ" },
        "items": {
          "type": "array",
          "x-prompt-write": "集約内エンティティ（識別子を持ち状態が変わる）を列挙。無ければ空。",
          "items": {
            "type": "object",
            "required": ["name", "identifier", "description"],
            "properties": {
              "name":        { "type": "string", "x-prompt-write": "エンティティ名。" },
              "identifier":  { "type": "string", "x-prompt-write": "識別子の概念名。" },
              "description": { "type": "string", "x-prompt-write": "役割を1文で。" },
              "attributes": {
                "type": "array",
                "x-prompt-write": "属性（値オブジェクトで表現）を列挙。",
                "items": {
                  "type": "object",
                  "required": ["name", "meaning"],
                  "properties": {
                    "name":    { "type": "string", "x-prompt-write": "属性名。" },
                    "meaning": { "type": "string", "x-prompt-write": "意味を1文で。" }
                  }
                }
              }
            }
          }
        }
      }
    },

    "CommandsBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 5,
      "x-render-level": 2,
      "x-prompt-query": "集約の公開コマンド(状態変更メソッド)を持ちます。集約の振る舞いの核。各コマンドは不変条件を守りイベントを発行します。",
      "x-render": [
        { "as": "section", "from": "items", "titleFrom": "name", "each": [
          { "as": "paragraph", "from": "description" },
          { "as": "table", "heading": "引数", "from": "params", "columns": [
            { "field": "name", "header": "引数" },
            { "field": "meaning", "header": "意味" }
          ] },
          { "as": "list", "heading": "発行イベント", "from": "emits" }
        ] }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "Commands" },
        "title":     { "type": "string", "const": "コマンド" },
        "items": {
          "type": "array",
          "x-prompt-write": "集約が公開する状態変更コマンドを列挙（命令形・ドメイン語彙）。例: 確定する、取り消す。",
          "items": {
            "type": "object",
            "required": ["name", "description"],
            "properties": {
              "name":        { "type": "string", "x-prompt-write": "コマンド名（命令形）。例: 確定する" },
              "description": { "type": "string", "x-prompt-write": "何をするか・どの不変条件を守るかを1文で。" },
              "params": {
                "type": "array",
                "x-prompt-write": "コマンドの引数（ドメインデータ）を列挙。無ければ空。",
                "items": {
                  "type": "object",
                  "required": ["name", "meaning"],
                  "properties": {
                    "name":    { "type": "string", "x-prompt-write": "引数名。" },
                    "meaning": { "type": "string", "x-prompt-write": "意味を1文で。" }
                  }
                }
              },
              "emits": {
                "type": "array",
                "x-prompt-write": "このコマンドが発行するドメインイベント名（過去形）を列挙。無ければ空。",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },

    "DomainEventsBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 6,
      "x-render-level": 2,
      "x-prompt-query": "集約が発行するドメインイベント(過去形・発行契機・ペイロード)を持ちます。",
      "x-render": [
        { "as": "section", "from": "items", "titleFrom": "name", "each": [
          { "as": "keyvalue", "pairs": [ { "label": "発行契機", "from": "raisedBy" } ] },
          { "as": "table", "heading": "ペイロード", "from": "payload", "columns": [
            { "field": "name", "header": "項目" },
            { "field": "meaning", "header": "意味" }
          ] }
        ] }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "DomainEvents" },
        "title":     { "type": "string", "const": "ドメインイベント" },
        "items": {
          "type": "array",
          "x-prompt-write": "発行するドメインイベントを列挙。無ければ空。",
          "items": {
            "type": "object",
            "required": ["name", "raisedBy"],
            "properties": {
              "name":     { "type": "string", "x-prompt-write": "イベント名（必ず過去形）。例: OrderConfirmed / 注文が確定された" },
              "raisedBy": { "type": "string", "x-prompt-write": "どのコマンド/条件で発行されるか。例: 確定する コマンドの成功時。" },
              "payload": {
                "type": "array",
                "x-prompt-write": "イベントが運ぶデータを列挙。無ければ空。",
                "items": {
                  "type": "object",
                  "required": ["name", "meaning"],
                  "properties": {
                    "name":    { "type": "string", "x-prompt-write": "項目名。" },
                    "meaning": { "type": "string", "x-prompt-write": "意味を1文で。" }
                  }
                }
              }
            }
          }
        }
      }
    },

    "DomainServicesBlock": {
      "type": "object",
      "required": ["blockType", "title", "items"],
      "x-render-order": 7,
      "x-render-level": 2,
      "x-prompt-query": "業務サービス(ステートレス・複数集約にまたがる計算)を持ちます。",
      "x-render": [
        { "as": "table", "from": "items", "columns": [
          { "field": "name", "header": "業務サービス" },
          { "field": "description", "header": "説明" }
        ] }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "DomainServices" },
        "title":     { "type": "string", "const": "業務サービス" },
        "items": {
          "type": "array",
          "x-prompt-write": "複数集約にまたがる/集約に収まらない計算ロジックを列挙。1集約で完結するなら空。",
          "items": {
            "type": "object",
            "required": ["name", "description"],
            "properties": {
              "name":        { "type": "string", "x-prompt-write": "業務サービス名。" },
              "description": { "type": "string", "x-prompt-write": "何を計算するか・どの集約を参照するかを1文で。" }
            }
          }
        }
      }
    },

    "LifecycleBlock": {
      "type": "object",
      "required": ["blockType", "title", "transitions"],
      "x-render-order": 8,
      "x-render-level": 2,
      "x-prompt-query": "集約の状態遷移(状態→契機→遷移先)を持ちます。",
      "x-render": [
        { "as": "table", "from": "transitions", "columns": [
          { "field": "from", "header": "状態" },
          { "field": "trigger", "header": "契機" },
          { "field": "to", "header": "遷移先" }
        ] }
      ],
      "properties": {
        "blockType": { "type": "string", "const": "Lifecycle" },
        "title":     { "type": "string", "const": "ライフサイクル" },
        "transitions": {
          "type": "array",
          "x-prompt-write": "集約の状態遷移を列挙（状態→契機(コマンド/イベント)→遷移先）。状態を持たない集約なら空。",
          "items": {
            "type": "object",
            "required": ["from", "trigger", "to"],
            "properties": {
              "from":    { "type": "string", "x-prompt-write": "遷移元の状態。例: PENDING" },
              "trigger": { "type": "string", "x-prompt-write": "遷移の契機（コマンド/イベント）。例: 確定する" },
              "to":      { "type": "string", "x-prompt-write": "遷移先の状態。例: CONFIRMED" }
            }
          }
        }
      }
    },

    "UnitTestScenariosBlock": {
      "type": "object",
      "required": ["blockType", "title", "gherkin"],
      "x-render-order": 9,
      "x-render-level": 2,
      "x-test-scenario": true,
      "x-prompt-query": "集約の不変条件を検証するユニットテスト仕様(Gherkin)を持ちます。HTML に表示され .feature にも render され実行されます。",
      "x-render": [ { "as": "code", "from": "gherkin", "lang": "gherkin" } ],
      "properties": {
        "blockType": { "type": "string", "const": "UnitTestScenarios" },
        "title":     { "type": "string", "const": "ユニットテスト仕様" },
        "gherkin": {
          "type": "string",
          "x-prompt-write": "集約の不変条件/コマンドを 1ルール1シナリオ で Gherkin(Feature/Scenario/Given-When-Then)。ドメインオブジェクトを直接操作する観点（例: order.確定する()）。"
        }
      }
    },

    "ActorIntentBlock": {
      "type": "object",
